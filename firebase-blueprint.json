{
  "entities": {
    "Psychologist": {
      "title": "Psychologist",
      "description": "Profile information of the psychologist",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Unique identifier of the psychologist matching auth.uid"
        },
        "name": {
          "type": "string",
          "description": "Full name of the psychologist"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "crp": {
          "type": "string",
          "description": "Professional registration number (CRP)"
        },
        "specialties": {
          "type": "string",
          "description": "Areas of specialization"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["userId", "name", "email", "crp", "createdAt"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Information about a patient",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the patient"
        },
        "psychologistId": {
          "type": "string",
          "description": "UID of the psychologist who owns this patient record"
        },
        "name": {
          "type": "string",
          "description": "Full name of the patient"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the patient"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "Date of birth"
        },
        "cpf": {
          "type": "string",
          "description": "Brazilian identity document CRP/CPF check"
        },
        "notes": {
          "type": "string",
          "description": "General non-sensitive notes, e.g., preferred contact methods"
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "description": "Is the patient active or inactive"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Record creation timestamp"
        }
      },
      "required": ["psychologistId", "name", "status", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "An appointment scheduled between a psychologist and a patient",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "psychologistId": {
          "type": "string",
          "description": "UID of the psychologist"
        },
        "patientId": {
          "type": "string",
          "description": "ID of the patient"
        },
        "patientName": {
          "type": "string",
          "description": "Name of the patient denormalized for search"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Format YYYY-MM-DD"
        },
        "time": {
          "type": "string",
          "description": "Format HH:MM"
        },
        "duration": {
          "type": "integer",
          "description": "Duration in minutes"
        },
        "type": {
          "type": "string",
          "enum": ["presential", "online"],
          "description": "Type of consultation"
        },
        "status": {
          "type": "string",
          "enum": ["scheduled", "completed", "canceled"],
          "description": "Appointment status"
        },
        "notes": {
          "type": "string",
          "description": "Administrative notes"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["psychologistId", "patientId", "patientName", "date", "time", "type", "status", "createdAt", "updatedAt"]
    },
    "MedicalRecord": {
      "title": "MedicalRecord",
      "description": "A secure, digital clinical medical record of a session",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "psychologistId": {
          "type": "string",
          "description": "UID of the psychologist"
        },
        "patientId": {
          "type": "string",
          "description": "ID of the patient"
        },
        "patientName": {
          "type": "string",
          "description": "Name of the patient"
        },
        "sessionDate": {
          "type": "string",
          "format": "date",
          "description": "Session date"
        },
        "title": {
          "type": "string",
          "description": "Brief record title, e.g., 'Sessão 5 - Evolução'"
        },
        "sessionSummary": {
          "type": "string",
          "description": "Subjective summary of the patient's state"
        },
        "clinicalObservations": {
          "type": "string",
          "description": "Objective clinical observations and analysis"
        },
        "therapeuticPlan": {
          "type": "string",
          "description": "Next steps or therapeutic tasks proposed"
        },
        "isLocked": {
          "type": "boolean",
          "description": "Once locked, clinical notes become read-only to satisfy secure health record invariants"
        },
        "lockedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was locked and signed"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["psychologistId", "patientId", "patientName", "sessionDate", "title", "sessionSummary", "isLocked", "createdAt", "updatedAt"]
    },
    "FinancialTransaction": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "psychologistId": {
          "type": "string"
        },
        "patientId": {
          "type": "string"
        },
        "patientName": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense"]
        },
        "amount": {
          "type": "number"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "paymentMethod": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["paid", "pending"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["psychologistId", "type", "amount", "date", "category", "status", "createdAt"]
    },
    "HealthReceipt": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "psychologistId": {
          "type": "string"
        },
        "patientId": {
          "type": "string"
        },
        "patientName": {
          "type": "string"
        },
        "patientCpf": {
          "type": "string"
        },
        "patientEmail": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "type": {
          "type": "string",
          "enum": ["payment_receipt", "health_report", "therapeutic_prescription"]
        },
        "value": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "signatureLocked": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["psychologistId", "patientId", "patientName", "patientCpf", "date", "type", "value", "description", "signatureLocked", "createdAt"]
    }
  },
  "firestore": {
    "psychologists/{psychologistId}": {
      "schema": "Psychologist",
      "description": "Psychologist master profile directory"
    },
    "patients/{patientId}": {
      "schema": "Patient",
      "description": "Directory of patients managed by psychologists"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Calendar logs of consult sessions"
    },
    "medical_records/{recordId}": {
      "schema": "MedicalRecord",
      "description": "Highly sensitive clinical evaluation notes and transcripts"
    },
    "transactions/{transactionId}": {
      "schema": "FinancialTransaction",
      "description": "Financial ledger of incomes and expenses"
    },
    "health_receipts/{receiptId}": {
      "schema": "HealthReceipt",
      "description": "Legal consultation receipts and prescriptions"
    }
  }
}

